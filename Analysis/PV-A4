### Step 1: Extract the search filter into a reusable hook

**Before** (same code in 4 files):
```js
// Landing.jsx, Admin.jsx, PublicVault.jsx, SharedVault.jsx
const [search, setSearch] = useState('');
const filteredPrompts = activePrompts.filter(p =>
  (p.name || '').toLowerCase().includes(search.toLowerCase()) ||
  (p.body || '').toLowerCase().includes(search.toLowerCase())
);
```

**After** — create one hook:

```
📁 src/hooks/usePromptFilter.js  ← NEW FILE
```

```js
// src/hooks/usePromptFilter.js
import { useState, useMemo } from 'react';

export function usePromptFilter(prompts = []) {
  const [search, setSearch] = useState('');

  const activePrompts = useMemo(
    () => prompts.filter(p => !p.isDeleted),
    [prompts]
  );

  const filteredPrompts = useMemo(() => {
    if (!search.trim()) return activePrompts;
    const q = search.toLowerCase();
    return activePrompts.filter(p =>
      (p.name || '').toLowerCase().includes(q) ||
      (p.body || '').toLowerCase().includes(q) ||
      (p.tags?.some(tag => tag.toLowerCase().includes(q)))
    );
  }, [activePrompts, search]);

  return { search, setSearch, filteredPrompts, totalCount: activePrompts.length };
}
```

**Now in each page:**
```js
const { search, setSearch, filteredPrompts, totalCount } = usePromptFilter(prompts);
```

**Effort:** 20 minutes. **Files changed:** 5 (1 new + 4 pages simplified).

